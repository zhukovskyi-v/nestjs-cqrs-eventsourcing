{
  "name": "@repo/contracts",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "check-types": "tsc --noEmit"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "dependencies": {
    "@orpc/contract": "^1.14.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}